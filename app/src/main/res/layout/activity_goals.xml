<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?attr/colorPrimary"
    tools:context=".GoalsActivity">

    <Button
        android:id="@+id/open_nav_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Menu"
        app:backgroundTint="@color/darker_blue_nontransparent"
        android:textColor="@color/white"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"/>

    <include layout="@layout/nav_drawer" />

   
    <Spinner
        android:id="@+id/workout_spinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp">

       
        <EditText
            android:id="@+id/goal_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Enter goal (%)"
            android:textColor="@color/text_color"
            android:inputType="numberDecimal" />

        
        <Button
            android:id="@+id/save_goal_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:backgroundTint="@color/darker_blue_nontransparent"
            android:textColor="@color/white"
            android:text="Save" />
    </LinearLayout>

    
    <TextView
        android:id="@+id/saved_goal_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current Goal: --%"
        android:layout_marginTop="16dp" />

    
    <TextView
        android:id="@+id/volume_change_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Weekly Volume Change: --%"
        android:layout_marginTop="16dp" />

    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp">

        
        <Spinner
            android:id="@+id/week1_spinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

       
        <Spinner
            android:id="@+id/week2_spinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp" />

        
        <Button
            android:id="@+id/compare_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compare"
            app:backgroundTint="@color/darker_blue_nontransparent"
            android:textColor="@color/white"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    
    <TextView
        android:id="@+id/comparison_result_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Comparison Result: --%"
        android:layout_marginTop="16dp" />

</LinearLayout>