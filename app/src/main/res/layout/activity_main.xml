<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="?attr/colorPrimary"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    
    <com.google.android.material.button.MaterialButton
        android:id="@+id/open_nav_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_margin="16dp"
        app:backgroundTint="@color/darker_blue_nontransparent"
        android:textColor="@color/white"
        android:layerType="software"
        android:shadowColor="#FFFFFFFF"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="8"
        android:text="Menu" />

    <Button
        android:id="@+id/theme_toggle_button"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_alignParentTop="true"
        android:layout_marginVertical="16dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="16dp"
        android:layerType="software"
        android:shadowColor="#FFFFFFFF"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="8"
        android:text="Theme"
        app:backgroundTint="@color/darker_blue_nontransparent"
        android:textColor="@color/white" />



   
    <LinearLayout
        android:id="@+id/nav_drawer"
        android:layout_width="250dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:background="@color/darker_blue_nontransparent"
        android:elevation="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        
        <Button
            android:id="@+id/workouts_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:backgroundTint="@color/blue"
            android:textColor="@color/white"
            android:text="@string/workouts" />

        <Button
            android:id="@+id/stats_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:backgroundTint="@color/blue"
            android:textColor="@color/white"
            android:text="@string/stats" />

        <Button
            android:id="@+id/goals_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:backgroundTint="@color/blue"
            android:textColor="@color/white"
            android:text="Goals" />

        

    </LinearLayout>

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:layout_centerInParent="true"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        app:srcCompat="@drawable/dumbell" />






</RelativeLayout>