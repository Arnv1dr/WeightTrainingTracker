<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="NightThemeWeightTrainingTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <!-- <item name="colorPrimary">@color/my_dark_primary</item> -->
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/grey</item>

        <item name="buttonStyle">@style/CustomButtonStyle</item>

        <!-- Background color -->
        <item name="android:background">@color/grey</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/darker_blue_nontransparent</item>
        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@color/darker_blue_nontransparent</item>
        <!-- Text color -->
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Define a custom button style -->
    <style name="CustomButtonStyle" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
    </style>
</resources>