<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="LightThemeWeightTrainingTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="colorPrimary">@color/light_grey</item>
        <item name="android:statusBarColor">@color/darker_blue_nontransparent</item>
        <item name="android:textColor">@color/medium_grey</item>
        <item name="android:navigationBarColor">@color/darker_blue_nontransparent</item>
        <item name="buttonStyle">@style/CustomButtonStyle</item>
        <item name="hintTextColor">@color/medium_grey</item>
        <item name="android:textColorHint">@color/medium_grey</item>
    </style>

    <style name="CustomCalendarMonth" parent="LightThemeWeightTrainingTracker">
        <item name="android:textColorPrimary">@color/black</item>
    </style>

    <style name="Theme.WeightTrainingTracker" parent="LightThemeWeightTrainingTracker" />

    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="materialButtonStyle">@style/MyButtonStyle</item>
    </style>

    <style name="MyButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/blue</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <!-- Define a custom button style -->
    <style name="CustomButtonStyle" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
    </style>
</resources>